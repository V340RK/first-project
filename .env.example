# Скопіюй цей файл у .env (без .example) і заповни реальними значеннями.
# .env ІГНОРУЄТЬСЯ git-ом — ключі ніколи не потраплять у репозиторій.

# === Binance Futures ===
# Testnet: https://testnet.binancefuture.com  (безкоштовно, без реальних грошей)
# Prod:    https://www.binance.com/en/futures  (реальні гроші, НЕ вмикай поки не впевнений)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# === Notifications (опційно) ===
# Для Telegram-алертів про трейди/помилки. Поки можна лишити порожнім.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
